# Asana Connector Configuration
# Copy this to .env and fill in with real values from:
# - https://app.asana.com/0/my-apps (for ASANA_API_TOKEN)
# - https://app.asana.com/0/<workspace-id> (for workspace/project IDs)

# Required: Asana Personal Access Token (PAT)
# Never commit the actual token; use env var or .env.local
ASANA_API_TOKEN=your-personal-access-token-here

# Required: Asana Workspace ID
ASANA_WORKSPACE_ID=your-workspace-gid-here

# Required: NWW Portfolio ID (created by bootstrap)
ASANA_PORTFOLIO_ID=your-nww-portfolio-gid-here

# Optional: Enable live Asana reporting (default: disabled for safety)
# ENABLE_ASANA_REPORTING=true

# Optional: Disable Asana integration entirely
# DISABLE_ASANA=false

# Project-Specific
ASANA_PROJECT_SPELLSIM=your-spell-simulator-project-gid-here
