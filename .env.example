# Asana Connector (NWW) — server/CLI-only configuration.
# Copy to `.env` and fill in real values. NEVER commit a filled-in `.env`.
# `.env` files are already git-ignored.

# Personal Access Token (PAT) from https://app.asana.com/0/my-apps
# Keep this secret. Do NOT expose it in a browser bundle.
ASANA_ACCESS_TOKEN=

# Optional: workspace GID (used for scoping / future workspace-level calls).
ASANA_WORKSPACE_ID=

# Destination project GID for the spell-simulator reports.
ASANA_PROJECT_SPELLSIM=

# Optional: post updates as comments on a single existing task instead of
# creating a new task per report. Takes precedence over the project when set.
ASANA_TASK_ID=

# Reporting is opt-in. Set to 1 (or true) to actually contact Asana.
# When unset/false, the reporter is a no-op and simulator behavior is unchanged.
ASANA_REPORTING_ENABLED=

# Test-only: set to 1 to allow the opt-in live Asana test suite to run.
# Leave unset for normal/CI runs so tests stay fully mocked.
RUN_LIVE_ASANA_TESTS=
