# Asana Connector Configuration
# Copy this to .env and fill in the token from:
# - https://app.asana.com/0/my-apps (for ASANA_API_TOKEN)
#
# Workspace/project GIDs below are the real bootstrapped values (not secrets).
# Only ASANA_API_TOKEN is a secret — never commit the real token.
#
# BROWSER SAFETY: the Asana PAT must NEVER be exposed in a client/browser bundle.
# Asana reporting runs server-side / CLI only. Do not read ASANA_API_TOKEN from
# any code that ships to the browser.

# Required: Asana Personal Access Token (PAT) — SECRET, server/CLI only
ASANA_API_TOKEN=your-personal-access-token-here

# Asana Workspace ID (bootstrapped 2026-07-08)
ASANA_WORKSPACE_ID=1216280230062995

# Project GID for Wha-Spell Simulator Glyph Mastery (bootstrapped 2026-07-08)
ASANA_PROJECT_SPELLSIM=1216393144202019

# --- Tier / mode ---
# Account is on Asana FREE tier: portfolios and custom fields are NOT available.
# The connector degrades to the free-tier fallback: metrics are written into the
# task description + a "Metrics JSON" block (schema nww.metrics.v1) rather than
# custom fields. Set these once you upgrade to a paid plan.
ASANA_TIER=free
NWW_FREE_TIER_FALLBACK=true
# ASANA_PORTFOLIO_ID=            # Advanced tier only — unset on free tier

# Optional: Enable live Asana reporting (default: disabled for safety)
# ENABLE_ASANA_REPORTING=true

# Optional: Disable Asana integration entirely
# DISABLE_ASANA=false

# Shadow Garden integration stubs (names only; keep real values local)
COMFYUI_URL=http://127.0.0.1:8189
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=
ATLASSIAN_DOMAIN=
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
CONFLUENCE_BASE_URL=
CONFLUENCE_SPACE_KEY=
GITHUB_TOKEN=
GH_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# HARPA names are local placeholders until an approved adapter contract exists.
HARPA_API_URL=
HARPA_API_KEY=

# --- Discord status_notify (PAUSED by default; Asuna Point-0 surface) ---
# Secrets policy: env_only. Metadata: tools/discord_asuna_point0_unify.py
# Dry-run: python3 tools/discord_local/notify.py ping
# Live post requires BOTH ENABLE_DISCORD=1 and DISCORD_LIVE_OK=1.
# ENABLE_DISCORD=0
# DISCORD_LIVE_OK=0
# DISCORD_WEBHOOK_URL=
# DISCORD_BOT_TOKEN=
# DISCORD_TOKEN=
# DISCORD_CHANNEL_ID=
# DISCORD_GUILD_ID=

# --- DeepSeek / Ollama (local-open-weights preferred; eastern white-moon partner) ---
# Secrets policy: env_only. Prefer 127.0.0.1 Ollama over remote DeepSeek API.
# Never commit real values. Metadata catalog: tools/deepseek_asuna_point0_unify.py
# Alias: tools/deepseek_asuna_zero_unify.py
# Central ledger: tools/perplexity_asuna_central_control.py
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODELS=
# Remote DeepSeek API is opt-in only (leave unset for local-only):
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_LOCAL_ENABLED=false

# --- Kimi 3 (3rd leverage: Asuna Point-0 completion → local open-weights mesh) ---
# Secrets policy: env_only. Metadata: tools/kimi3_asuna_point0_unify.py
# Transition plan: shadow_garden_handoff/bridges/kimi3_local_open_weights_transition.json
# Prefer 127.0.0.1 Ollama. Arm transition only after approval:
# KIMI3_TRANSITION_ARMED=0
# KIMI_LOCAL_ENABLED=false
# KIMI_API_KEY=
# MOONSHOT_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.5

# --- Grok / xAI (Harmony-6 white-moon partner; eastern corner with DeepSeek) ---
# Secrets policy: env_only. Metadata: tools/grok_xai_asuna_point0_unify.py
# Corner weave: tools/white_moon_eastern_corner_unify.py
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# GROK_TEXT_MODEL=grok-3
# GROK_VOICE_MODEL=grok-voice-latest
# GROK_IMAGE_MODEL=grok-image-latest
# GROK_VIDEO_MODEL=grok-video-latest
# GROK_AUDIO_MODEL=grok-audio-latest

# --- Stripe (Payments / Billing / Connect / Invoicing / Tax) ---
# Secrets policy: env_only. Copy to .env or ~/ShadowGarden/.env (chmod 600).
# Prefer a restricted key (rk_test_… / rk_live_…) over a full secret key (sk_…).
# Never commit real values. Never put secret/RAK keys in Vite client code.
# Publishable key (pk_) is the only Stripe key allowed in the browser.
# Local scaffold: node tools/stripe_local/server.mjs (dry-run unless STRIPE_LIVE_OK=1)
# See docs/stripe-integration-plan.md
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
STRIPE_SECRET_KEY=rk_test_your-restricted-or-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here
STRIPE_API_VERSION=2026-06-24.dahlia
# STRIPE_LOCAL_PORT=4242
# STRIPE_LIVE_OK=0
# Optional Connect return URLs (local-first)
# STRIPE_CONNECT_RETURN_URL=http://127.0.0.1:5173/billing/return
# STRIPE_CONNECT_REFRESH_URL=http://127.0.0.1:5173/billing/refresh
# Flip only after Tax Registrations exist in Dashboard (otherwise tax stays zero)
# STRIPE_TAX_ENABLED=false
