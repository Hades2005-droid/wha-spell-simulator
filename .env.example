# Asana Connector Configuration
# Copy this to .env and fill in the token from:
# - https://app.asana.com/0/my-apps (for ASANA_API_TOKEN)
#
# Workspace/project GIDs below are the real bootstrapped values (not secrets).
# Only ASANA_API_TOKEN is a secret — never commit the real token.
#
# BROWSER SAFETY: the Asana PAT must NEVER be exposed in a client/browser bundle.
# Asana reporting runs server-side / CLI only. Do not read ASANA_API_TOKEN from
# any code that ships to the browser.

# Required: Asana Personal Access Token (PAT) — SECRET, server/CLI only
ASANA_API_TOKEN=your-personal-access-token-here

# Asana Workspace ID (bootstrapped 2026-07-08)
ASANA_WORKSPACE_ID=1216280230062995

# Project GID for Wha-Spell Simulator Glyph Mastery (bootstrapped 2026-07-08)
ASANA_PROJECT_SPELLSIM=1216393144202019

# --- Tier / mode ---
# Account is on Asana FREE tier: portfolios and custom fields are NOT available.
# The connector degrades to the free-tier fallback: metrics are written into the
# task description + a "Metrics JSON" block (schema nww.metrics.v1) rather than
# custom fields. Set these once you upgrade to a paid plan.
ASANA_TIER=free
NWW_FREE_TIER_FALLBACK=true
# ASANA_PORTFOLIO_ID=            # Advanced tier only — unset on free tier

# Optional: Enable live Asana reporting (default: disabled for safety)
# ENABLE_ASANA_REPORTING=true

# Optional: Disable Asana integration entirely
# DISABLE_ASANA=false
